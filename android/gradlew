##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell available, you may
#       specify it by setting the SHELL variable when running this script.
#       For example: SHELL=/bin/ksh myscript
#
#   (2) The slurped sed script is necessary to deal with Windows' hidden
#       character class ranges and its fundamental incompatibility with Unices.
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a softlink
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}	# leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}
export APP_HOME
export APP_NAME
export APP_BASE_NAME

cd "$APP_HOME" || exit 1

if [ -n "$JAVA_HOME" ]; then
    javaExe="$JAVA_HOME/bin/java"
else
    javaExe="java"
fi

"$javaExe" \
        -Dorg.gradle.appname="$APP_BASE_NAME" \
        -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" \
        org.gradle.wrapper.GradleWrapperMain "$@"
